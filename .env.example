# Get this from your Neon database dashboard (Vercel Postgres / Neon)
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional: secret key required to run the user seed endpoint
SEED_SECRET=

# Resend API key for email reminders (get from resend.com)
RESEND_API_KEY=

# Secret for Vercel cron jobs (auto-set by Vercel, or set manually)
CRON_SECRET=

# Email address to send reminders from (must be verified in Resend)
REMINDER_FROM_EMAIL=
